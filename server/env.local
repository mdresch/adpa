# Backend Environment Variables for Local Development
NODE_ENV=development
PORT=5000

# Database Configuration (using Neon PostgreSQL)
# SECURITY: Real credentials removed - use your own Neon database
DB_HOST=your-neon-instance.neon.tech
DB_PORT=5432
DB_NAME=adpa_db
DB_USER=your_db_user
DB_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_URL=postgresql://YOUR_USER:YOUR_PASSWORD@your-instance.neon.tech/adpa_db?sslmode=require

# Redis Configuration (using Upstash Redis)
# SECURITY: Real credentials removed - use your own Upstash Redis URL
# Format: rediss://default:YOUR_PASSWORD@your-instance.upstash.io:6379
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@your-instance.upstash.io:6379

# JWT Secret
JWT_SECRET=your-development-jwt-secret-key-here-make-it-long-and-secure

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Optional: Enable debug logging
DEBUG=*

# Vercel AI Gateway (retrieved from database, but can be set here for fallback)
# AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key-here

