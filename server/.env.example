# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adpa_db
DB_USER=postgres
DB_USER=postgres
DB_PASSWORD=password

# RAG / MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=adpa_rag
VOYAGE_API_KEY=your-voyage-ai-api-key
VOYAGE_EMBEDDING_MODEL=voyage-4-large
VOYAGE_RERANK_MODEL=rerank-2

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ (queues; optional - used for job queues)
# RABBITMQ_URL=amqp://localhost
# Max messages on project-data-extraction DLQ; only applied when queue is created. Set higher (e.g. 50000) if DLQ hits broker limit (e.g. 20000).
# QUEUE_PROJECT_DATA_EXTRACTION_DLQ_MAX_LENGTH=50000

# Neo4j (optional, parallel to PostgreSQL/Redis; for graph/knowledge use cases)
# Leave NEO4J_URI unset to disable Neo4j; server runs normally without it.
# For Neo4j Aura: use neo4j+s://... from console.neo4j.io; wait ~60s after instance creation before connecting.
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password
# NEO4J_DATABASE=neo4j
# NEO4J_CONNECT_TIMEOUT_MS=15000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Logging Configuration
LOG_LEVEL=info

# AI Provider API Keys (Optional - configure in admin panel)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# AI Gateway (Vercel)
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ADPA Framework <noreply@adpa.com>

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key

# Integration Configuration (Optional)
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Notification Integrations
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-url
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Monitoring and Analytics (Optional)
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=your-ga-id
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_URL=https://eu-central-1-1.aws.cloud2.influxdata.com
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=your-bucket

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL_DEFAULT=3600
CACHE_TTL_USER=1800
CACHE_TTL_TEMPLATE=3600
CACHE_TTL_DOCUMENT=1800

# Adobe PDF Services Configuration
ADOBE_PDF_ENABLED=false
ADOBE_CLIENT_ID=your-adobe-client-id
ADOBE_CLIENT_SECRET=your-adobe-client-secret
ADOBE_ORGANIZATION_ID=your-adobe-organization-id
ADOBE_ACCOUNT_ID=your-adobe-account-id
ADOBE_PRIVATE_KEY=your-adobe-private-key
ADOBE_OUTPUT_DIR=./generated-documents/adobe-pdf
ADOBE_TEMP_DIR=./temp/adobe-pdf

# Document Generation Configuration
DOCUMENT_OUTPUT_DIR=./generated-documents
DOCUMENT_TEMP_DIR=./temp
# OpenTelemetry Tracing Configuration
TRACING_ENABLED=true
OTLP_ENDPOINT=http://localhost:4318/v1/traces
SERVICE_NAME=adpa-backend