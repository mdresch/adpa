# ==============================================
# Core Configuration
# ==============================================
PORT=5000
LOG_LEVEL=info
# Allow Supabase TLS certificate (connection pooling causes cert chain issues)
# SECURITY WARNING: Setting NODE_TLS_REJECT_UNAUTHORIZED=0 bypasses TLS verification. 
# It is strictly for local development and will cause the server to fail to start in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0
# Frontend URL (for CORS and auto-disable logs)
FRONTEND_URL=http://localhost:3005

# ==============================================
# Database Configuration (PostgreSQL / Supabase)
# ==============================================
# Supabase PostgreSQL - Connection Pooling (RECOMMENDED)
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Local Development Note:
# For production, keep the pooler URL. If you experience connection timeouts (e.g. ECHECKOUTTIMEOUT on port 6543)
# during local dev on Windows, use the direct connection on port 5432 instead:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# Also, set ADPA_ALLOW_INSECURE_TLS=true in local development server/.env to allow self-signed/custom certificates if needed.
# ADPA_ALLOW_INSECURE_TLS=true

# Supabase API Configuration
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Standard DB Connection Details (Supabase)
DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_SSL=true

# Optional tuning for database connectivity
# DB_CONN_TIMEOUT_MS=30000       # how long to wait for a socket connection
# DB_QUERY_TIMEOUT_MS=15000      # how long to wait for a simple test query
# DB_MAX_RETRIES_PER_METHOD=1    # number of attempts before falling back to other hosts

# Legacy / Alternative Connection Strings
POSTGRES_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&pgbouncer=true&sslmode=require

# ==============================================
# Redis Configuration (Railway & Upstash Fallback)
# ==============================================
REDIS_URL=redis://default:[PASSWORD]@[HOST]:[PORT]
UPSTASH_REDIS_URL=rediss://default:[PASSWORD]@[HOST]:[PORT]
REDIS_HOST=your-redis-host
REDIS_PORT=your-redis-port
REDIS_PASSWORD=your-redis-password

# ==============================================
# Authentication & Security
# ==============================================
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
ENCRYPTION_KEY=your-32-byte-encryption-key
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=your-nextauth-secret

# ==============================================
# AI Services & LLMs
# ==============================================
# Langfuse tracing
# ENABLE_LANGFUSE_TRACING=true enables OpenTelemetry OTLP export.
# ENABLE_LANGFUSE_NATIVE_SDK=true enables direct Langfuse SDK tracing (/api/public/ingestion).
# LANGFUSE_DEBUG_TRACING=true enables per-request trace/flush debug logs.
# Set ENABLE_LANGFUSE_TRACING=false + ENABLE_LANGFUSE_NATIVE_SDK=true to use SDK-only tracing.
# LANGFUSE_BASE_URL is used to derive the OTLP endpoint when LANGFUSE_OTLP_ENDPOINT is not set.
# LANGFUSE_OTLP_AUTH_HEADER can override Basic auth when your OTLP collector expects a custom token/header.
ENABLE_LANGFUSE_TRACING=false
ENABLE_LANGFUSE_NATIVE_SDK=true
LANGFUSE_DEBUG_TRACING=false

# Google AI (Gemini) - Used by DocumentTypeDetectionService
GOOGLE_AI_API_KEY=your-google-ai-api-key
# Optional: override model for Quality Audit only (default: gemini-3.1-flash-lite)
# QUALITY_AUDIT_GOOGLE_MODEL=gemini-3.1-flash-lite

# Ollama (Local LLMs)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Voyage AI (Embeddings)
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBEDDING_MODEL=voyage-4-large
VOYAGE_RERANK_MODEL=rerank-2

# Tavily (Search)
TAVILY_API_KEY=your-tavily-api-key

# ==============================================
# NoSQL & Vector Databases
# ==============================================
# MongoDB optional vector store for RAG chunks (canonical docs stay in SQL)
MONGODB_URI=mongodb+srv://[USER]:[PASSWORD]@[CLUSTER].mongodb.net/
MONGODB_DB_NAME=adpa_rag
# Atlas Vector Search index name on the chunks collection (default: vector_search_index)
MONGODB_VECTOR_INDEX=vector_search_index
# Embedding pipeline: atlas = Atlas DB trigger fills embeddings after insert; server = Voyage during sync
MONGODB_EMBEDDING_MODE=atlas
# When true, /api/rag/query and assisted document search prefer MongoDB vector search (falls back to pgvector)
MONGODB_RAG_ENABLED=false

# Pinecone (Vector DB)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=adpa-rag-index
PINECONE_INDEX_HOST=your-pinecone-index-host

# Neo4j (Graph DB)
NEO4J_URI=neo4j+s://[HOST]
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
# Aura cold start can exceed 15s during parallel backend init; use 30000 for AuraDB Free
NEO4J_CONNECT_TIMEOUT_MS=30000

# InfluxDB (Metrics)
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=adpa
INFLUXDB_DATABASE=adpa-metrics

# ==============================================
# Messaging & Queues
# ==============================================
# RabbitMQ
RABBITMQ_URL=amqps://[USER]:[PASSWORD]@[HOST]/[VHOST]
# QUEUE_PROJECT_DATA_EXTRACTION_DLQ_MAX_LENGTH=50000

# ==============================================
# Email (SMTP)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ADPA Quality Control <noreply@adpa.com>"