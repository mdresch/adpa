# ADPA - server/.env.sample
# Safe example of environment variables grouped by category.
# Do NOT commit secrets to source control. Use a secret manager for production.

############################
# Authentication & Secrets
############################
# JWT / session
JWT_SECRET="replace-with-a-secure-random-uuid-or-secret"
SESSION_SECRET="replace-with-a-secure-session-secret"
BCRYPT_ROUNDS="12"

# Stack / public keys (safe to expose in client builds)
NEXT_PUBLIC_STACK_PROJECT_ID="your-stack-project-id"
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY="your-publishable-client-key"
STACK_SECRET_SERVER_KEY="replace-with-server-side-stack-secret"

# Sentry / monitoring
SENTRY_DSN=""

############################
# Database / ORM (choose canonical keys for your setup)
############################
# Preferred: single DATABASE_URL for convenience (Postgres)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL="postgresql://neondb_owner:password@db-host:5432/adpa_db?sslmode=require"

# Optional (unpooled / lower-level libs):
PGHOST="db-host"
PGUSER="neondb_owner"
PGPASSWORD="password"
PGDATABASE="adpa_db"
PGPORT="5432"

# Prisma / explicit URL if used
POSTGRES_PRISMA_URL="postgresql://neondb_owner:password@db-host:5432/adpa_db?sslmode=require"

############################
# Cache / Redis / KV
############################
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# Upstash or managed KV tokens (store securely)
ADPA_RGA_REDIS_KV_URL=""
ADPA_RGA_REDIS_KV_REST_API_URL=""
ADPA_RGA_REDIS_KV_REST_API_TOKEN=""

############################
# Third-party / External APIs
############################
# OpenAI / Azure OpenAI
OPENAI_API_KEY=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"

# Google / other providers
GOOGLE_AI_API_KEY=""
GOOGLE_ANALYTICS_ID=""

# GitHub OAuth (for auth flows)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_TOKEN=""

# SharePoint (Azure AD app)
SHAREPOINT_CLIENT_ID=""
SHAREPOINT_CLIENT_SECRET=""
SHAREPOINT_TENANT_ID=""

# Slack / Teams / Webhooks
SLACK_BOT_TOKEN=""
TEAMS_WEBHOOK_URL=""

############################
# Adobe PDF Services
############################
ADOBE_PDF_ENABLED=true
ADOBE_CLIENT_ID=""
ADOBE_CLIENT_SECRET=""
ADOBE_ORGANIZATION_ID=""
ADOBE_ACCOUNT_ID=""
# For ADOBE_PRIVATE_KEY provide the PEM or compact key via secrets (avoid multiline in plaintext)
ADOBE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...replace-with-private-key...\n-----END PRIVATE KEY-----"
ADOBE_OUTPUT_DIR="./generated-documents/adobe-pdf"
ADOBE_TEMP_DIR="./temp/adobe-pdf"

############################
# Email / SMTP
############################
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-app-password"
SMTP_FROM="ADPA Framework <noreply@example.com>"

############################
# Application config & runtime
############################
NODE_ENV="development"
PORT="5000"
FRONTEND_URL="http://localhost:3000"
LOG_LEVEL="info"

# Rate limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000"

# Cache TTLs (seconds)
CACHE_TTL_DEFAULT="3600"
CACHE_TTL_DOCUMENT="1800"
CACHE_TTL_TEMPLATE="3600"
CACHE_TTL_USER="1800"

# Upload settings
UPLOAD_ALLOWED_TYPES="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain"
UPLOAD_MAX_SIZE="10485760" # bytes (10 MB)

############################
# Feature flags / platform tokens
############################
VERCEL_OIDC_TOKEN=""
NEXT_PUBLIC_...=""

############################
# Notes
############################
# - Replace placeholders with real secrets in your local .env or CI secret store.
# - Keep .env trimmed to only the keys your environment needs. Remove duplicate DB keys.
# - Recommended canonical variables:
#   - DATABASE_URL (for most libraries)
#   - POSTGRES_PRISMA_URL (if using Prisma)
#   - REDIS_URL
#   - OPENAI_API_KEY / AZURE_OPENAI_API_KEY
# - For production, use a secrets manager (Azure Key Vault, GitHub Secrets, or your cloud provider).
