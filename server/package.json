{
  "name": "adpa-backend",
  "version": "2.0.0",
  "description": "ADPA Backend API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit false || echo 'Build completed with warnings'",
    "build:strict": "tsc",
    "start": "tsx src/server.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "migrate": "node -r dotenv/config scripts/run-migrations.js",
    "migrate:financial": "tsx scripts/run-financial-migrations.ts",
    "create-admin": "tsx scripts/create-admin-user.ts",
    "fix-encryption": "tsx scripts/fix-encryption-migration.ts",
    "seed:baselines": "tsx scripts/seed-baseline-data.ts",
    "drift:recompute": "tsx scripts/recompute-drift.ts"
  },
  "dependencies": {
    "@adobe/pdfservices-node-sdk": "^4.1.0",
    "@ai-sdk/mistral": "^2.0.20",
    "@ai-sdk/openai": "^2.0.56",
    "@google/generative-ai": "^0.24.1",
    "@types/jsdom": "^27.0.0",
    "@types/marked": "^5.0.2",
    "@types/node-schedule": "^2.1.8",
    "@types/uuid": "^10.0.0",
    "ai": "^5.0.70",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "jsdom": "^27.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.0",
    "marked": "^16.4.0",
    "multer": "^1.4.5-lts.1",
    "node-schedule": "^2.1.1",
    "openai": "^4.28.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "puppeteer": "^22.0.0",
    "redis": "^5.6.0",
    "sharp": "^0.33.2",
    "showdown": "^2.1.0",
    "socket.io": "^4.8.1",
    "turndown": "^7.2.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
