{
  "name": "adpa-backend",
  "version": "1.0.0",
  "description": "ADPA Framework Backend API Server",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:e2e": "jest --config jest.config.e2e.js",
    "test:e2e:pipeline": "jest --config jest.config.e2e.js --testPathPattern=pipeline.test.ts",
    "test:e2e:performance": "jest --config jest.config.e2e.js --testPathPattern=performance.test.ts",
    "test:e2e:stress": "jest --config jest.config.e2e.js --testPathPattern=stress.test.ts",
    "test:e2e:all": "powershell -ExecutionPolicy Bypass -File scripts/run-e2e-tests.ps1",
    "test:e2e:simple": "powershell -ExecutionPolicy Bypass -File scripts/run-simple-e2e-tests-simple.ps1",
    "test:e2e:coverage": "jest --config jest.config.e2e.js --coverage",
    "migrate": "tsx src/database/migrate.ts",
    "seed": "tsx src/database/seed.ts",
    "seed-adpa": "tsx src/database/seed-adpa-documents.ts",
    "seed-all": "tsx src/database/seed-all.ts",
    "migrate:vercel": "tsx scripts/migrate-to-vercel.ts",
    "seed:vercel": "tsx scripts/seed-vercel.ts",
    "migrate:openai-enhanced": "tsx src/database/migrate-openai-enhanced.ts",
    "demo:adobe-pdf": "tsx src/demo/adobe-pdf-demo.ts",
    "test:adobe-pdf": "tsx src/test-adobe-integration.ts"
  },
  "dependencies": {
    "@adobe/pdfservices-node-sdk": "^4.0.1",
    "@google/generative-ai": "^0.2.1",
    "@mistralai/mistralai": "^1.10.0",
    "openai": "^4.20.1",
    "@azure/msal-node": "^3.6.3",
    "@neondatabase/serverless": "^1.0.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^6.15.0",
    "file-saver": "^2.0.5",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "marked": "^12.0.0",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "puppeteer": "^22.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "redis": "^4.6.10",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/marked": "^5.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}
