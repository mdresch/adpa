{
  "name": "server",
  "version": "1.0.0",
  "description": "ADPA Server - Project Management and Document Processing Backend",
  "main": "src/server.ts",
  "scripts": {
    "start": "node -r tsconfig-paths/register dist/server/src/server.js",
    "start:api": "ADPA_PROCESS_ROLE=api node -r tsconfig-paths/register dist/server/src/server.js",
    "start:worker": "ADPA_PROCESS_ROLE=worker node -r tsconfig-paths/register dist/server/src/worker.js",
    "predev": "node ../scripts/ensure-zod-v4-exports.mjs",
    "dev": "nodemon --exec tsx src/server.ts",
    "lint": "eslint .",
    "build": "node scripts/build-production.mjs && tsc-alias -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --config jest.config.js --maxWorkers=50%",
    "test:unit:mock": "jest --config jest.config.unit.js --maxWorkers=50%",
    "test:features": "node scripts/run-governed-features.mjs",
    "test:rag-features": "node scripts/run-governed-features.mjs rag",
    "test:doc-gen": "node scripts/run-governed-features.mjs doc-gen",
    "test:coverage:features": "jest --config jest.config.coverage.unit.js --testPathPattern=modules/rag --collectCoverageFrom=src/modules/rag/**/*.ts --maxWorkers=2",
    "test:coverage:unit": "jest --config jest.config.coverage.unit.js --maxWorkers=50%",
    "report:coverage:unit": "node scripts/report-unit-coverage.mjs",
    "audit:test-reach": "node scripts/audit-test-reach.mjs",
    "verify:governed-features": "node scripts/verify-governed-features.mjs",
    "test:integration": "docker-compose -f docker-compose.test.yml up -d && jest --config jest.config.integration.js; docker-compose -f docker-compose.test.yml down",
    "test:integration:watch": "jest --config jest.config.integration.js --watch --detectOpenHandles",
    "test:harness:verify": "tsx scripts/verify-test-harness.ts",
    "seed": "tsx src/database/seed.ts",
    "seed:compliance-rulesets": "tsx --require dotenv/config src/modules/compliance/seedRulesets.ts",
    "migrate": "npx tsx scripts/run-migrations.ts",
    "migrate:src": "npx tsx scripts/run-src-db-migrations.ts",
    "migrate:reset": "npx tsx scripts/run-migrations.ts --reset",
    "migrate:dev": "npx tsx scripts/run-migrations.ts --reset && npm run seed",
    "migrate:baseline": "node scripts/generate-migration-from-db.js",
    "check-db": "node scripts/check-database-schema.js",
    "fix-stakeholders": "node scripts/run-stakeholders-fix.ts",
    "clear-failed-jobs": "node scripts/clean-stuck-database-jobs.ts",
    "init-qdrant": "tsx scripts/init-qdrant-collection.ts",
    "init-gkg-schema": "tsx scripts/init-gkg-schema.ts",
    "generate-embeddings": "tsx scripts/generate-embeddings.ts",
    "verify:jina": "tsx scripts/verify-jina.ts",
    "sync:ai": "tsx scripts/sync-ai-providers.ts"
  },
  "keywords": [],
  "author": "Menno Drescher",
  "license": "ISC",
