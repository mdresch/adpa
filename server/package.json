    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "puppeteer": "^22.0.0",
    "recharts": "^3.3.0",
    "redis": "^5.6.0",
    "sharp": "^0.33.2",
    "showdown": "^2.1.0",
    "socket.io": "^4.8.1",
    "turndown": "^7.2.1",
