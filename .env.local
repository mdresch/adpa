NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=http://localhost:5000

# Docker PostgreSQL Database
POSTGRES_URL="postgres://postgres:password@localhost:5432/adpa_db"
POSTGRES_PRISMA_URL="postgres://postgres:password@localhost:5432/adpa_db?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://postgres:password@localhost:5432/adpa_db"
POSTGRES_USER="postgres"
POSTGRES_HOST="localhost"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="adpa_db"

# JWT Secret for development
JWT_SECRET="your-development-jwt-secret-key-here-make-it-long-and-secure"

# Application Settings
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="ADPA"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Redis Configuration (for Docker setup)
REDIS_URL="redis://localhost:6379"

# File Upload Settings
MAX_FILE_SIZE="10485760"  # 10MB
ALLOWED_FILE_TYPES="pdf,doc,docx,txt,md"

# AI Provider Settings (optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Email Settings (optional)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Logging
LOG_LEVEL="debug"

