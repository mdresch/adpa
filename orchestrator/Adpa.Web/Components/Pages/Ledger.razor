@page "/ledger"
@using Adpa.Orchestrator.Models.Rituals
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Governance Ledger</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Governance Ledger</h1>
        <span class="badge bg-primary">Phase 0: Ideation</span>
    </div>

    @if (summaries == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading ritual data...</span>
            </div>
            <p class="mt-3">Consulting the Governance Ledger...</p>
        </div>
    }
    else if (!summaries.Any())
    {
        <div class="alert alert-info">
            No ideation rituals have been recorded in the ledger yet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var summary in summaries)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-start border-primary border-4">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@summary.Title</h5>
                            <p class="card-text text-muted small">@summary.ExecutiveSummary</p>
                            
                            <hr />
                            
                            <div class="mb-2">
                                <strong>Problem Statement:</strong>
                                <p class="small mb-0">@summary.ProblemStatement</p>
                            </div>

                            <div>
                                <strong>Proposed Solution:</strong>
                                <p class="small mb-0">@summary.ProposedSolution</p>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-end">
                            <button class="btn btn-outline-primary btn-sm">Review Ritual Audit</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<IdeationSummary>? summaries;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            summaries = await client.GetFromJsonAsync<List<IdeationSummary>>("/api/ritual/ledger/ideation");
        }
        catch (Exception ex)
        {
            // Logging would happen via ILogger in a production scenario
            summaries = new List<IdeationSummary>();
        }
    }
}
