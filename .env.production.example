# ==============================================================================
# ADPA "ABSOLUTE ZERO" PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy these values into your Render (Frontend) and Northflank (Backend) dashboards.
# All services below are available via FREE TIERS from the suggested providers.

# --- Core Settings ---
NODE_ENV="production"
PORT="5000"

# --- Database (PostgreSQL) ---
# Recommended Provider: Neon.tech (Free Tier)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require"
MORPHIC_DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require"

# --- Redis (Cache) ---
# Recommended Provider: Upstash.com (Free Tier)
REDIS_URL="rediss://default:[PASSWORD]@[HOST]:[PORT]"

# --- MongoDB (RAG & Storage) ---
# Recommended Provider: MongoDB Atlas (Free Tier)
MONGODB_URI="mongodb+srv://[USER]:[PASSWORD]@[CLUSTER].mongodb.net/adpa_rag?retryWrites=true&w=majority"

# --- Neo4j (Graph Database) ---
# Recommended Provider: Neo4j Aura (Free Tier)
NEO4J_URI="bolt://[HOST]:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your-secure-password"

# --- RabbitMQ (Messaging) ---
# Recommended Provider: CloudAMQP (Free Tier)
RABBITMQ_URL="amqp://[USER]:[PASSWORD]@[HOST]/[VHOST]"

# --- Security ---
JWT_SECRET="generate-a-long-random-string-here"
SESSION_SECRET="another-long-random-string-here"
ENABLE_AUTH="true"

# --- URLs (Update these AFTER deploying to Render/Northflank) ---
# The Northflank public URL (e.g. adpa-api.northflank.app)
NEXT_PUBLIC_API_URL="https://[YOUR-NORTHFLANK-BACKEND-URL]"
# The Render public URL (e.g. adpa-ui.onrender.com)
FRONTEND_URL="https://[YOUR-RENDER-FRONTEND-URL]"

# --- AI Providers (Add your free-tier keys here) ---
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
TAVILY_API_KEY=""
# OpenUI GenUI document workspace (Next.js /api/chat when systemPrompt is sent)
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-large-latest"
