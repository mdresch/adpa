## Performance Optimization

### Database
```typescript
// ✅ GOOD - Use indexes
CREATE INDEX idx_documents_project_id ON documents(project_id);
CREATE INDEX idx_documents_user_id ON documents(user_id);
CREATE INDEX idx_documents_created_at ON documents(created_at DESC);

// Use JSONB efficiently
SELECT content->>'title' as title
FROM documents
WHERE content @> '{"status": "published"}';

// Connection pooling
const pool = new Pool({
  max: 20,
  idleTimeoutMillis: 30000,
  connectionTimeoutMillis: 2000
});
```

### Redis Caching
```typescript
// Cache frequent queries
async function getProject(projectId: string) {
  const cacheKey = `project:${projectId}`;
  
  // Try cache first
  const cached = await redis.get(cacheKey);
  if (cached) return JSON.parse(cached);
  
  // Query database
  const project = await pool.query(
    'SELECT * FROM projects WHERE id = $1',
    [projectId]
  );
  
  // Cache for 5 minutes
  await redis.setex(cacheKey, 300, JSON.stringify(project.rows[0]));
  
  return project.rows[0];
}

// Invalidate cache on update
async function updateProject(projectId: string, data: any) {
  await pool.query('UPDATE projects SET ... WHERE id = $1', [projectId]);
  await redis.del(`project:${projectId}`); // Invalidate cache
}
```

### Next.js Optimization
```typescript
// Image optimization
import Image from 'next/image';
<Image src="/logo.png" alt="Logo" width={200} height={50} />

// Dynamic imports for heavy components
const HeavyChart = dynamic(() => import('@/components/HeavyChart'), {
  loading: () => <Spinner />,
  ssr: false
});

// API route caching
export default async function handler(req: NextApiRequest, res: NextApiResponse) {
  res.setHeader('Cache-Control', 's-maxage=60, stale-while-revalidate');
  // ...
}
```

