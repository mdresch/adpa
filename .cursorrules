## Development Guidelines

### Code Style & Standards

#### TypeScript
```typescript
// ✅ GOOD - Proper typing
interface GenerateDocumentParams {
  templateId: string;
  projectId: string;
  data: Record<string, unknown>;
  outputFormat: 'markdown' | 'pdf' | 'docx';
}

async function generateDocument(params: GenerateDocumentParams): Promise<Document> {
  // Implementation
}

// ❌ BAD - No typing
async function generateDocument(params: any) {
  // Implementation
}
```

#### React Components
```typescript
// ✅ GOOD - Functional component with proper types
interface ButtonProps {
  onClick: () => void;
  children: React.ReactNode;
  variant?: 'primary' | 'secondary';
}

export function Button({ onClick, children, variant = 'primary' }: ButtonProps) {
  return (
    <button onClick={onClick} className={cn('btn', variant)}>
      {children}
    </button>
  );
}

// ❌ BAD - No types, class component
export class Button extends React.Component {
  render() {
    return <button onClick={this.props.onClick}>{this.props.children}</button>;
  }
}
```

#### API Routes
```typescript
// ✅ GOOD - Proper error handling, validation, types
router.post('/documents/generate', 
  authenticate,
  validateRequest(generateDocumentSchema),
  async (req: Request, res: Response, next: NextFunction) => {
    try {
      const document = await documentService.generate(req.body);
      res.json({ success: true, data: document });
    } catch (error) {
      next(error); // Pass to error handler
    }
  }
);

// ❌ BAD - No validation, poor error handling
router.post('/documents/generate', async (req, res) => {
  const document = await documentService.generate(req.body);
  res.json(document);
});
```

#### Database Queries
```typescript
// ✅ GOOD - Parameterized queries
const result = await pool.query(
  'SELECT * FROM documents WHERE project_id = $1 AND user_id = $2',
  [projectId, userId]
);

// ❌ BAD - SQL injection risk
const result = await pool.query(
  `SELECT * FROM documents WHERE project_id = '${projectId}'`
);
```

#### Markdown Storage
```typescript
// ✅ GOOD - Store as Markdown
await pool.query(
  'INSERT INTO documents (id, content, format) VALUES ($1, $2, $3)',
  [id, markdownContent, 'markdown']
);

// Export to PDF when needed
const pdf = await convertMarkdownToPdf(markdownContent);
res.setHeader('Content-Type', 'application/pdf');
res.send(pdf);

// ❌ BAD - Storing PDF directly
await pool.query(
  'INSERT INTO documents (id, content) VALUES ($1, $2)',
  [id, pdfBuffer]
);
```

#### Supabase Client Usage
```typescript
// ✅ GOOD - Using Supabase client with RLS
const { data, error } = await supabase
  .from('documents')
  .select('*')
  .eq('project_id', projectId)
  .order('created_at', { ascending: false });

if (error) throw error;

// ✅ GOOD - Using service role for admin operations
const { data: adminData, error: adminError } = await supabaseAdmin
  .from('users')
  .update({ role: 'admin' })
  .eq('id', userId);

// ❌ BAD - Bypassing RLS when not needed
const { data } = await pool.query('SELECT * FROM documents'); // No user context

// ✅ GOOD - Real-time subscription
const channel = supabase
  .channel(`project:${projectId}`)
  .on('postgres_changes', {
    event: 'UPDATE',
    schema: 'public',
    table: 'documents',
    filter: `project_id=eq.${projectId}`
  }, handleDocumentUpdate)
  .subscribe();

// Clean up on unmount
return () => {
  supabase.removeChannel(channel);
};
```

