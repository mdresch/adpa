# Test environment variables
NODE_ENV=test
JWT_SECRET=test-jwt-secret

# Vercel Postgres (use local test database or mock)
POSTGRES_URL=postgres://postgres:password@localhost:5432/test_db
POSTGRES_PRISMA_URL=postgres://postgres:password@localhost:5432/test_db?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://postgres:password@localhost:5432/test_db
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=test_db

# Vercel KV (use local Redis or mock)
KV_URL=redis://localhost:6379
KV_REST_API_URL=http://localhost:8079
KV_REST_API_TOKEN=mock_token
KV_REST_API_READ_ONLY_TOKEN=mock_read_token