# Vercel KV Environment Variables
# These will be automatically populated by Vercel when you create a KV database
# For local development, copy these from your Vercel dashboard

# Connection URL for the KV database (Redis protocol)
KV_URL=redis://default:password@host:port

# REST API URL for the KV database
KV_REST_API_URL=https://your-kv-database-url.vercel-storage.com

# Authentication token for the KV REST API (full access)
KV_REST_API_TOKEN=your_api_token_here

# Authentication token for the KV REST API (read-only access)
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token_here

# Other environment variables for your application
# ...