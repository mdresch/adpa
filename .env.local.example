# Vercel KV Environment Variables
# These will be automatically populated by Vercel when you create a KV database
# For local development, copy these from your Vercel dashboard

# Connection URL for the KV database (Redis protocol)
KV_URL=redis://default:password@host:port

# REST API URL for the KV database
KV_REST_API_URL=https://your-kv-database-url.vercel-storage.com

# Authentication token for the KV REST API (full access)
KV_REST_API_TOKEN=your_api_token_here

# Authentication token for the KV REST API (read-only access)
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token_here

# Other environment variables for your application
# ...

# Vercel Postgres Environment Variables
# These will be automatically populated by Vercel when you create a Postgres database
# For local development, you need to manually add these values after creating your Vercel Postgres database

# Connection strings
POSTGRES_URL="postgres://username:password@host:5432/database"
POSTGRES_PRISMA_URL="postgres://username:password@host:5432/database?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://username:password@host:5432/database"

# Morphic database (used by /api/morphic/*)
MORPHIC_DATABASE_URL="postgres://username:password@host:5432/database"

# Individual connection parameters
POSTGRES_USER="username"
POSTGRES_HOST="host"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="database"

# Other environment variables
JWT_SECRET="your-jwt-secret"
NEXTAUTH_URL="http://localhost:3005"
NEXTAUTH_SECRET="your-nextauth-secret"

# Bentley iTwin Viewer (Bentley standard naming - recommended)
# Register your app at https://developer.bentley.com
# Application Type: SPA (Single Page Web Application)
# Scope: itwin-platform
IMJS_AUTH_CLIENT_CLIENT_ID=your_bentley_client_id
IMJS_AUTH_CLIENT_SCOPES=itwins:read imodels:read
IMJS_AUTH_CLIENT_REDIRECT_URI=http://localhost:3005/signin-callback

# Bentley iTwin Viewer (Next.js naming - also supported)
# NEXT_PUBLIC_ITWIN_CLIENT_ID=your_bentley_client_id
# NEXT_PUBLIC_ITWIN_REDIRECT_URI=http://localhost:3005/signin-callback

# Microsoft Dynamics 365 Guides Integration
# Register your app at https://portal.azure.com (Azure Active Directory > App registrations)
# Required API permissions: Dynamics CRM > user_impersonation
D365_TENANT_ID=your-azure-tenant-id
D365_CLIENT_ID=your-app-client-id
D365_CLIENT_SECRET=your-app-client-secret
D365_ENVIRONMENT_URL=https://your-org.crm.dynamics.com
D365_GUIDES_APP_ID=your-guides-app-id

# ==============================================
# TLS & Security Configuration
# ==============================================
# CRITICAL: TLS Certificate Validation
# NODE_TLS_REJECT_UNAUTHORIZED=0 DISABLES TLS verification and is ONLY for local development.
# NEVER set this to "0" in production - it bypasses security and allows man-in-the-middle attacks.
# Default: undefined (TLS enabled and required)
# Local development-only (if needed for self-signed certs): NODE_TLS_REJECT_UNAUTHORIZED=0
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ==============================================
# RPAS Governance Orchestrator (C# / Aspire)
# ==============================================
# Ritual templates on /ai POST to /api/Ritual/* — proxied here when set (server-only).
# Get the URL from Aspire dashboard (apiservice http endpoint) or orchestrator launchSettings.
# ORCHESTRATOR_URL=http://localhost:5xxx
# Optional: call orchestrator directly from the browser (skip Next rewrite)
# NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:5xxx
# Set when ORCHESTRATOR_URL is configured (enables ritual UI hints)
# NEXT_PUBLIC_ORCHESTRATOR_PROXY=true

# Express backend (default). Next.js rewrites /api/* here except Ritual when ORCHESTRATOR_URL is set.
# BACKEND_URL=http://localhost:5000

# ==============================================
# GenUI document workspace LLM (POST /api/chat with systemPrompt)
# ==============================================
# Provider: mistral (default) | google (Gemini via OpenAI-compatible API)
GENUI_LLM_PROVIDER=mistral
# Next.js loads .env.local over .env — set GenUI vars here (not only in .env).
# Optional UI label in Step 2 header (should match GENUI_LLM_PROVIDER)
# NEXT_PUBLIC_GENUI_LLM_PROVIDER=google

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# Google Gemini (when GENUI_LLM_PROVIDER=google) — same key as AI Studio / backend OpenUI chat
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
# GENUI_GOOGLE_MODEL=gemini-2.5-flash-lite
# Large governance docs can hit Google/Mistral 429 (TPM). Prefer flash-lite; enable billing in AI Studio if needed.
# GEMINI_MODEL_OVERRIDE=gemini-2.5-flash

# ==============================================
# Langfuse Telemetry (SDK-only)
# ==============================================
ENABLE_LANGFUSE_TRACING=false
ENABLE_LANGFUSE_NATIVE_SDK=true
LANGFUSE_DEBUG_TRACING=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANG_FUSE_BASE_URL=https://cloud.langfuse.com

# ==============================================
# Firebase Configuration (Local Emulation)
# ==============================================
# Required for Firebase SDK initialization during development
NEXT_PUBLIC_FIREBASE_API_KEY="demo-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="demo-adpa.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="adpa-frontend"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="demo-adpa.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abcdef123456"

# Real Firebase in local dev: leave USE_AUTH_EMULATOR unset or "false" (recommended when not running emulators).
# Emulator workflow: set USE_AUTH_EMULATOR=true and run `npx firebase-tools emulators:start` (auth default :9099).
NEXT_PUBLIC_FIREBASE_USE_AUTH_EMULATOR="false"
# Port should match auth emulator port in firebase.json (default: 9099)
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
